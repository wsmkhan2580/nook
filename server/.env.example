# MongoDB connection string (from MongoDB Atlas or local)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/instaclone

# Server port
PORT=

# Cloudinary credentials (from cloudinary.com dashboard)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend origin (for CORS)
CLIENT_URL=

# Secret key for signing JWT auth tokens — use a long random string
JWT_SECRET=

